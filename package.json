{
  "name": "pathlockd-nodejs-client",
  "version": "0.3.1",
  "description": "Typed Node.js/TypeScript gRPC client for pathlockd — fast, scalable, opinionated path-based distributed locking primitives over TiKV.",
  "license": "AGPL-3.0-or-later",
  "author": "alexpacio",
  "os": [
    "linux",
    "darwin"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexpacio/pathlockd-nodejs-client.git"
  },
  "keywords": [
    "pathlockd",
    "tikv",
    "grpc",
    "distributed-lock",
    "path-lock",
    "fencing"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "proto",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
